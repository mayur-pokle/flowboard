# ─────────────────────────────────────────────────────────────────────
# Database — Vercel Postgres (Neon)
# Vercel auto-populates these when you attach a Postgres database to
# your project. For local dev, copy the values from the Vercel
# dashboard → Storage → Postgres → .env.local tab.
# ─────────────────────────────────────────────────────────────────────
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ─────────────────────────────────────────────────────────────────────
# NextAuth (auth.js v4)
# ─────────────────────────────────────────────────────────────────────
# Long random string — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Public URL of your deployment. Required by NextAuth callbacks.
NEXTAUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────
# Email magic links — Resend SMTP
# Sign up at resend.com, verify a sender domain, then paste the API key.
# ─────────────────────────────────────────────────────────────────────
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=re_yourResendApiKey
# Use onboarding@resend.dev for testing without a verified domain.
EMAIL_FROM="Flowboard <onboarding@resend.dev>"

# Optional: extra allowed emails (comma-separated). Unioned with
# lib/allowlist.ts.
ALLOWED_EMAILS=

# ─────────────────────────────────────────────────────────────────────
# AI providers
# ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-latest

# ─────────────────────────────────────────────────────────────────────
# Slack
# ─────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────────────
# Brand context (optional — these are stored in the DB and editable
# from /settings/api. The env vars only act as fallback defaults when
# the DB row is empty).
# ─────────────────────────────────────────────────────────────────────
BRAND_COMPANY_NAME=
BRAND_WEBSITE_URL=
BRAND_NICHE="B2B SaaS for finance teams"
BRAND_AUDIENCE="CFOs, controllers, and finance ops leaders at startups"
BRAND_PRODUCT_DESCRIPTION=
BRAND_VALUE_PROPOSITION=
BRAND_VOICE="Professional, direct, no marketing-speak."
BRAND_PRIMARY_CTA="Book a 20-min demo"
BRAND_PRIMARY_GEO="United States"
BRAND_COMPETITORS=
BRAND_SEED_KEYWORDS=
BRAND_TOPICS_TO_AVOID=

# ─────────────────────────────────────────────────────────────────────
# Cron
# ─────────────────────────────────────────────────────────────────────
CRON_SECRET=
